<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200" width="100%" height="100%">
  <defs>
    <style>
      /* --- CORE STYLES --- */
      .layer {
        fill: #e6e5db;
        stroke: #142e52;
        stroke-width: 3;
        stroke-linejoin: round;
        stroke-linecap: round;
      }
      
      .academic-text {
        stroke: #5a6572;
        stroke-width: 1.5;
        stroke-linecap: round;
        animation: fadeText 10s infinite;
      }

      .mask-line {
        stroke: white;
        stroke-width: 8;
        fill: none;
        stroke-linecap: round;
        stroke-dasharray: 250;
        stroke-dashoffset: 250;
        animation: drawJourney 10s infinite cubic-bezier(0.4, 0, 0.2, 1);
      }

      .journey-dashed {
        stroke: #f28f2c;
        stroke-width: 4;
        fill: none;
        stroke-linecap: round;
        stroke-dasharray: 6 6;
      }

      .reward-x {
        stroke: #f28f2c;
        stroke-width: 4;
        stroke-linecap: round;
        transform-origin: 165px 80px;
        animation: popX 10s infinite cubic-bezier(0.16, 1, 0.3, 1);
      }

      .reward-burst {
        fill: none;
        stroke: #f28f2c;
        transform-origin: 165px 80px;
        animation: burstX 10s infinite ease-out;
      }

      /* --- CSS ANIMATIONS --- */
      @keyframes fadeText {
        0%, 12% { opacity: 0.5; }
        22%, 90% { opacity: 0; }
        95%, 100% { opacity: 0.5; }
      }

      @keyframes drawJourney {
        0%, 25% { stroke-dashoffset: 250; opacity: 1; }
        45%, 85% { stroke-dashoffset: 0; opacity: 1; }
        90%, 100% { stroke-dashoffset: 0; opacity: 0; }
      }

      @keyframes popX {
        0%, 43% { opacity: 0; transform: scale(0.2); }
        46%, 85% { opacity: 1; transform: scale(1); }
        90%, 100% { opacity: 0; transform: scale(0.2); }
      }

      @keyframes burstX {
        0%, 43% { opacity: 0; transform: scale(0); stroke-width: 4; }
        46% { opacity: 1; transform: scale(1.2); stroke-width: 2; }
        55%, 100% { opacity: 0; transform: scale(2.5); stroke-width: 0; }
      }
    </style>

    <mask id="journey-mask">
      <path class="mask-line" d="M 35 110 C 50 140, 60 80, 85 95 C 105 105, 110 130, 135 110 C 150 95, 155 80, 165 80" />
    </mask>
  </defs>

  <rect width="200" height="200" fill="#e6e5db" rx="20" />

  <g>
    <!-- LAYER 1 -->
    <path class="layer">
      <animate attributeName="d"
        values="
          M 35 60 L 110 35 L 140 125 L 65 150 Z;
          M 35 60 L 110 35 L 140 125 L 65 150 Z;
          M 20 60 L 73 50 L 73 140 L 20 150 Z;
          M 20 60 L 73 50 L 73 140 L 20 150 Z;
          M 35 60 L 110 35 L 140 125 L 65 150 Z;
          M 35 60 L 110 35 L 140 125 L 65 150 Z
        "
        keyTimes="0; 0.15; 0.25; 0.85; 0.95; 1" dur="10s" repeatCount="indefinite" />
    </path>

    <!-- LAYER 2 -->
    <path class="layer">
      <animate attributeName="d"
        values="
          M 75 40 L 145 60 L 115 165 L 45 145 Z;
          M 75 40 L 145 60 L 115 165 L 45 145 Z;
          M 126 60 L 180 50 L 180 140 L 126 150 Z;
          M 126 60 L 180 50 L 180 140 L 126 150 Z;
          M 75 40 L 145 60 L 115 165 L 45 145 Z;
          M 75 40 L 145 60 L 115 165 L 45 145 Z
        "
        keyTimes="0; 0.15; 0.25; 0.85; 0.95; 1" dur="10s" repeatCount="indefinite" />
    </path>

    <!-- LAYER 3 -->
    <path class="layer">
      <animate attributeName="d"
        values="
          M 55 45 L 135 35 L 150 155 L 70 165 Z;
          M 55 45 L 135 35 L 150 155 L 70 165 Z;
          M 73 50 L 126 60 L 126 150 L 73 140 Z;
          M 73 50 L 126 60 L 126 150 L 73 140 Z;
          M 55 45 L 135 35 L 150 155 L 70 165 Z;
          M 55 45 L 135 35 L 150 155 L 70 165 Z
        "
        keyTimes="0; 0.15; 0.25; 0.85; 0.95; 1" dur="10s" repeatCount="indefinite" />
    </path>
  </g>

  <g class="academic-text">
    <line x1="60" y1="60" x2="132" y2="51" />
    <line x1="62" y1="75" x2="134" y2="66" />
    <line x1="64" y1="90" x2="120" y2="83" />
    <line x1="66" y1="105" x2="138" y2="96" />
    <line x1="68" y1="120" x2="140" y2="111" />
    <line x1="70" y1="135" x2="115" y2="129" />
  </g>

  <path class="journey-dashed" mask="url(#journey-mask)" d="M 35 110 C 50 140, 60 80, 85 95 C 105 105, 110 130, 135 110 C 150 95, 155 80, 165 80" />

  <g transform="rotate(-30 165 80)">
    <g class="reward-x">
      <line x1="158" y1="73" x2="172" y2="87" />
      <line x1="172" y1="73" x2="158" y2="87" />
    </g>
  </g>

  <circle cx="165" cy="80" r="10" class="reward-burst" />

</svg>
