<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 400" width="100%" height="100%">
  <style>
    /* Minimalist Apple-esque Styling */
    .bg { fill: #e6e5d8; }
    
    .grid-line {
      stroke: #142e52;
      stroke-width: 1;
      opacity: 0.08;
    }

    /* Common Animation Properties */
    .animated-path {
      fill: none;
      stroke-linecap: round;
      stroke-linejoin: round;
      /* Using pathLength="100" in markup normalizes lengths to exactly 100 */
      stroke-dasharray: 100;
      stroke-dashoffset: 100;
      animation: draw-line 8s cubic-bezier(0.4, 0, 0.2, 1) infinite;
    }

    /* Orange Brand Arc - Smooth */
    .brand-arc {
      stroke: #f28f2c;
      stroke-width: 6;
    }

    /* Blue Tactics Chaos - Sharp & Sporadic */
    .tactics-chaos {
      stroke: #142e52;
      stroke-width: 4;
    }

    /* Master Fade Group to ensure perfectly synced loop out */
    .sync-loop {
      animation: fade-out 8s linear infinite;
    }

    /* Keyframes */
    @keyframes draw-line {
      0%, 10% { stroke-dashoffset: 100; }
      /* Both finish drawing at the exact same time */
      75%, 100% { stroke-dashoffset: 0; }
    }

    @keyframes fade-out {
      0%, 80% { opacity: 1; }
      /* Smoothly fade to invisible before the loop restarts */
      92%, 100% { opacity: 0; }
    }
  </style>

  <rect class="bg" width="800" height="400" rx="16" />

  <g class="grid-line">
    <line x1="80" y1="320" x2="720" y2="320" />
    <line x1="80" y1="240" x2="720" y2="240" />
    <line x1="80" y1="160" x2="720" y2="160" />
    <line x1="80" y1="80" x2="720" y2="80" />
  </g>

  <path d="M 80 80 L 80 320 L 720 320" fill="none" stroke="#142e52" stroke-width="2" opacity="0.3" stroke-linecap="round" stroke-linejoin="round"/>

  <g class="sync-loop">
    
    <path class="animated-path tactics-chaos" pathLength="100" d="M 80 320 L 120 280 L 150 300 L 180 240 L 220 270 L 260 180 L 300 220 L 350 120 L 400 180 L 450 80 L 490 150 L 530 60 L 570 160 L 610 120 L 660 260 L 690 240 L 720 320" />
    
    <path class="animated-path brand-arc" pathLength="100" d="M 80 320 C 250 320, 500 180, 720 80" />
    
  </g>

</svg>
