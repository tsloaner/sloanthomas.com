<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200" width="100%" height="100%">
  <defs>
    <style>
      /* --- CORE STYLES --- */
      .wall {
        fill: none;
        stroke-width: 4;
        stroke-linecap: round;
        stroke-linejoin: round;
      }
      .stage-line {
        fill: none;
        stroke-width: 2;
        opacity: 0.4;
        stroke-linecap: round;
      }
      .consumer-dot {
        r: 6;
        animation: dotJourney 8s infinite, dotColor 8s infinite;
      }
      .success-rays {
        transform-origin: 115px 190px;
        animation: popSuccess 8s infinite cubic-bezier(0.16, 1, 0.3, 1);
      }

      /* --- CSS ANIMATIONS --- */
      @keyframes dotJourney {
        0%, 5% { transform: translate(100px, -5px); }
        18% { transform: translate(96px, 125px); }
        19%, 21%, 23%, 25%, 27%, 29% { transform: translate(93px, 125px); }
        20%, 22%, 24%, 26%, 28%, 30% { transform: translate(99px, 125px); }
        32% { transform: translate(96px, 125px); }
        40% { transform: translate(145px, 130px); }
        55% { transform: translate(105px, 170px); }
        65% { transform: translate(115px, 190px); }
        70%, 100% { transform: translate(115px, 230px); }
      }

      @keyframes dotColor {
        0%, 30% { fill: #142e52; }
        35%, 75% { fill: #f28f2c; }
        76%, 100% { fill: #142e52; }
      }

      @keyframes popSuccess {
        0%, 63% { opacity: 0; transform: scale(0.2); }
        65% { opacity: 1; transform: scale(1); }
        68%, 100% { opacity: 0; transform: scale(1.8); }
      }
    </style>
  </defs>

  <rect width="200" height="200" fill="#e6e5db" rx="20" />

  <g>
    <!-- LEFT WALL -->
    <path class="wall" stroke="#142e52">
      <animate attributeName="d"
        values="
          M 20 20 C 60 60, 60 60, 60 60 C 45 110, 45 110, 45 110 C 80 150, 75 190, 75 190;
          M 20 20 C 60 60, 60 60, 60 60 C 45 110, 45 110, 45 110 C 80 150, 75 190, 75 190;
          M 70 20 C 70 70, 120 70, 120 105 C 120 140, 70 140, 70 175 C 70 185, 80 190, 85 190;
          M 70 20 C 70 70, 120 70, 120 105 C 120 140, 70 140, 70 175 C 70 185, 80 190, 85 190;
          M 20 20 C 60 60, 60 60, 60 60 C 45 110, 45 110, 45 110 C 80 150, 75 190, 75 190;
          M 20 20 C 60 60, 60 60, 60 60 C 45 110, 45 110, 45 110 C 80 150, 75 190, 75 190
        "
        keyTimes="0; 0.3; 0.4; 0.8; 0.9; 1" dur="8s" repeatCount="indefinite" />
      <animate attributeName="stroke"
        values="#142e52; #142e52; #f28f2c; #f28f2c; #142e52; #142e52"
        keyTimes="0; 0.3; 0.4; 0.8; 0.9; 1" dur="8s" repeatCount="indefinite" />
    </path>

    <!-- RIGHT WALL -->
    <path class="wall" stroke="#142e52">
      <animate attributeName="d"
        values="
          M 180 20 C 130 65, 130 65, 130 65 C 150 105, 150 105, 150 105 C 115 145, 115 190, 115 190;
          M 180 20 C 130 65, 130 65, 130 65 C 150 105, 150 105, 150 105 C 115 145, 115 190, 115 190;
          M 130 20 C 130 70, 180 70, 180 105 C 180 140, 130 140, 130 175 C 130 185, 140 190, 145 190;
          M 130 20 C 130 70, 180 70, 180 105 C 180 140, 130 140, 130 175 C 130 185, 140 190, 145 190;
          M 180 20 C 130 65, 130 65, 130 65 C 150 105, 150 105, 150 105 C 115 145, 115 190, 115 190;
          M 180 20 C 130 65, 130 65, 130 65 C 150 105, 150 105, 150 105 C 115 145, 115 190, 115 190
        "
        keyTimes="0; 0.3; 0.4; 0.8; 0.9; 1" dur="8s" repeatCount="indefinite" />
      <animate attributeName="stroke"
        values="#142e52; #142e52; #f28f2c; #f28f2c; #142e52; #142e52"
        keyTimes="0; 0.3; 0.4; 0.8; 0.9; 1" dur="8s" repeatCount="indefinite" />
    </path>
  </g>

  <!-- THE INTERIOR LINES -->
  <g>
    <path class="stage-line" stroke="#142e52">
      <animate attributeName="d"
        values="
          M 60 60 C 83 60, 106 60, 130 65;
          M 60 60 C 83 60, 106 60, 130 65;
          M 100 40 C 100 60, 140 70, 140 90;
          M 100 40 C 100 60, 140 70, 140 90;
          M 60 60 C 83 60, 106 60, 130 65;
          M 60 60 C 83 60, 106 60, 130 65
        "
        keyTimes="0; 0.3; 0.4; 0.8; 0.9; 1" dur="8s" repeatCount="indefinite" />
      <animate attributeName="stroke"
        values="#142e52; #142e52; #f28f2c; #f28f2c; #142e52; #142e52"
        keyTimes="0; 0.3; 0.4; 0.8; 0.9; 1" dur="8s" repeatCount="indefinite" />
    </path>

    <path class="stage-line" stroke="#142e52">
      <animate attributeName="d"
        values="
          M 45 110 C 80 105, 115 105, 150 105;
          M 45 110 C 80 105, 115 105, 150 105;
          M 145 110 C 145 135, 105 135, 105 155;
          M 145 110 C 145 135, 105 135, 105 155;
          M 45 110 C 80 105, 115 105, 150 105;
          M 45 110 C 80 105, 115 105, 150 105
        "
        keyTimes="0; 0.3; 0.4; 0.8; 0.9; 1" dur="8s" repeatCount="indefinite" />
      <animate attributeName="stroke"
        values="#142e52; #142e52; #f28f2c; #f28f2c; #142e52; #142e52"
        keyTimes="0; 0.3; 0.4; 0.8; 0.9; 1" dur="8s" repeatCount="indefinite" />
    </path>

    <path class="stage-line" stroke="#142e52">
      <animate attributeName="d"
        values="
          M 62 130 C 85 130, 105 130, 128 130;
          M 62 130 C 85 130, 105 130, 128 130;
          M 100 160 C 100 175, 110 185, 120 185;
          M 100 160 C 100 175, 110 185, 120 185;
          M 62 130 C 85 130, 105 130, 128 130;
          M 62 130 C 85 130, 105 130, 128 130
        "
        keyTimes="0; 0.3; 0.4; 0.8; 0.9; 1" dur="8s" repeatCount="indefinite" />
      <animate attributeName="stroke"
        values="#142e52; #142e52; #f28f2c; #f28f2c; #142e52; #142e52"
        keyTimes="0; 0.3; 0.4; 0.8; 0.9; 1" dur="8s" repeatCount="indefinite" />
    </path>
  </g>

  <g class="success-rays">
    <line x1="115" y1="180" x2="115" y2="170" stroke="#f28f2c" stroke-width="3" stroke-linecap="round" />
    <line x1="115" y1="200" x2="115" y2="210" stroke="#f28f2c" stroke-width="3" stroke-linecap="round" />
    <line x1="105" y1="190" x2="95"  y2="190" stroke="#f28f2c" stroke-width="3" stroke-linecap="round" />
    <line x1="125" y1="190" x2="135" y2="190" stroke="#f28f2c" stroke-width="3" stroke-linecap="round" />
  </g>

  <circle cx="0" cy="0" class="consumer-dot" />

</svg>
