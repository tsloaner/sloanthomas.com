<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200" width="100%" height="100%">
  <defs>
    <style>
      /* --- CORE STYLES --- */
      .input-ray {
        fill: none;
        stroke-linecap: round;
        stroke-linejoin: round;
        stroke-dasharray: 20 150;
        animation: suckIntoPrism 10s cubic-bezier(0.4, 0, 0.2, 1) infinite;
      }
      
      .ray1 { stroke: #142e52; stroke-width: 3; }
      .ray2 { stroke: #5a6572; stroke-width: 2; }
      .ray3 { stroke: #142e52; stroke-width: 2.5; }
      
      .prism-group {
        transform-origin: 100px 105px;
      }
      
      .prism-face {
        fill: #e6e5db;
        stroke-width: 3;
        stroke-linejoin: round;
        animation: prismIdentity 10s infinite;
      }

      .beam-line {
        fill: none;
        stroke: #f28f2c;
        stroke-linecap: round;
        stroke-dasharray: 100 200;
        animation: shootBeam 10s cubic-bezier(0.16, 1, 0.3, 1) infinite;
      }
      
      .beam-core { stroke-width: 5; opacity: 1; }
      .beam-aura { stroke-width: 14; opacity: 0.25; }

      /* --- CSS ANIMATIONS --- */
      @keyframes suckIntoPrism {
        0%, 10% { stroke-dashoffset: 20; opacity: 0; }
        12% { opacity: 1; }
        40% { stroke-dashoffset: -100; opacity: 1; }
        40.1%, 100% { stroke-dashoffset: -100; opacity: 0; }
      }

      @keyframes prismIdentity {
        0%, 39% { stroke: #142e52; }
        40%, 70% { stroke: #f28f2c; }
        80%, 100% { stroke: #142e52; }
      }

      @keyframes shootBeam {
        0%, 39.9% { stroke-dashoffset: 100; opacity: 0; }
        40% { stroke-dashoffset: 100; opacity: 1; }
        43%, 75% { stroke-dashoffset: 0; opacity: 1; }
        80%, 100% { stroke-dashoffset: 0; opacity: 0; }
      }
    </style>

    <clipPath id="card-bound">
      <rect width="200" height="200" rx="20" />
    </clipPath>
  </defs>

  <rect width="200" height="200" fill="#e6e5db" rx="20" />

  <g clip-path="url(#card-bound)">
    <path class="input-ray ray1" pathLength="100" d="M 180 180 L 20 180 L 20 20 L 150 20 L 40 80 L 80 105" />
    <path class="input-ray ray2" pathLength="100" d="M 180 40 L 180 160 L 80 180 L 20 120 L 70 20 L 80 105" />
    <path class="input-ray ray3" pathLength="100" d="M 120 20 L 180 170 L 140 180 L 20 40 L 80 105" />
  </g>

  <g class="prism-group">
    <path class="prism-face" d="M 70 130 L 110 130 L 90 80 Z" />
    <path class="prism-face" d="M 110 130 L 130 115 L 110 65 L 90 80 Z" />
  </g>

  <g clip-path="url(#card-bound)">
    <line x1="115" y1="95" x2="230" y2="-20" class="beam-line beam-aura" pathLength="100" />
    <line x1="115" y1="95" x2="230" y2="-20" class="beam-line beam-core" pathLength="100" />
  </g>

</svg>
