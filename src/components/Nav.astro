---
import Logo from "./Logo.astro";
const { pathname } = Astro.url;
const links = [
  { name: "Home", href: "/" },
  { name: "Services", href: "/services" },
  { name: "Writing", href: "/writing" },
  { name: "About", href: "/about" },
  { name: "Contact", href: "/contact" },
];

const isActive = (href: string) => {
  if (href === "/") return pathname === "/" || pathname === "";
  if (href === "/writing") return pathname.startsWith("/writing");
  return pathname.startsWith(href);
};
---

<header
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-linen/0"
  id="main-header"
>
  <div
    class="max-w-[1200px] mx-auto px-6 h-28 flex items-center justify-between"
  >
    <a
      href="/"
      class="text-indigo focus:outline-none focus-visible:ring-2 focus-visible:ring-orange rounded-sm hover:text-indigo/80 relative z-50 transition-colors duration-300 flex items-center"
      aria-label="Thomas Sloan"
      id="logo-text"
    >
      <Logo class="w-12 h-12 -ml-2" />
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden lg:flex gap-8 items-center">
      {
        links.map((link) => (
          <a
            href={link.href}
            class:list={[
              "font-mono text-[14px] uppercase tracking-widest transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-orange rounded-sm",
              isActive(link.href) ? "text-orange" : "text-slate-blue hover:text-orange"
            ]}
          >
            {link.name}
          </a>
        ))
      }
    </nav>

    <!-- Mobile Menu Toggle -->
    <button
      id="mobile-menu-btn"
      class="lg:hidden p-3 -mr-1 text-indigo focus:outline-none focus-visible:ring-2 focus-visible:ring-orange rounded-sm relative z-50 transition-colors duration-300"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <svg
        class="w-6 h-6 transition-transform duration-300"
        id="hamburger-icon"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="1.5"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
      <svg
        class="w-6 h-6 transition-transform duration-300 hidden"
        id="close-icon"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="1.5"
          d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </div>

  <!-- Mobile Nav Overlay -->
  <div
    id="mobile-menu"
    class="fixed inset-0 bg-indigo z-40 lg:hidden flex-col justify-center items-center opacity-0 pointer-events-none transition-opacity duration-300 hidden"
  >
    <nav class="flex flex-col items-center gap-10">
      {
        links.map((link) => (
          <a
            href={link.href}
            class:list={[
              "font-mono text-lg uppercase tracking-widest transition-colors",
              isActive(link.href) ? "text-orange" : "text-linen hover:text-orange"
            ]}
          >
            {link.name}
          </a>
        ))
      }
    </nav>
  </div>
</header>
<div class="h-28"></div>
<!-- Spacer for fixed header -->

<script>
  let isMenuOpen = false;

  function initHeader() {
    const header = document.getElementById("main-header");
    const btn = document.getElementById("mobile-menu-btn");
    const menu = document.getElementById("mobile-menu");
    const hamburger = document.getElementById("hamburger-icon");
    const closeIcon = document.getElementById("close-icon");
    const logo = document.getElementById("logo-text");

    if (!header || !btn || !menu || !hamburger || !closeIcon || !logo) return;

    // Handle Scroll Backdrop
    const onScroll = () => {
      if (isMenuOpen) return;
      if (window.scrollY > 50) {
        header.classList.add(
          "bg-linen/95",
          "backdrop-blur-md",
          "shadow-[0_1px_0_rgba(20,46,82,0.05)]"
        );
        header.classList.remove("bg-linen/0");
      } else {
        header.classList.remove(
          "bg-linen/95",
          "backdrop-blur-md",
          "shadow-[0_1px_0_rgba(20,46,82,0.05)]"
        );
        header.classList.add("bg-linen/0");
      }
    };

    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();

    // Clean up old listeners (for astro view transitions if used later)
    btn.replaceWith(btn.cloneNode(true));
    const newBtn = document.getElementById("mobile-menu-btn") as HTMLButtonElement;

    // Shared close logic — used by both the toggle button and nav links
    const closeMenu = () => {
      isMenuOpen = false;
      newBtn.setAttribute("aria-expanded", "false");
      menu.classList.remove("opacity-100");
      menu.classList.add("opacity-0", "pointer-events-none");
      document.body.style.overflow = "";
      logo.classList.remove("text-linen");
      logo.classList.add("text-indigo");
      newBtn.classList.remove("text-linen");
      newBtn.classList.add("text-indigo");
      hamburger.classList.remove("hidden");
      closeIcon.classList.add("hidden");
      onScroll();
      setTimeout(() => {
        menu.classList.add("hidden");
        menu.classList.remove("flex");
      }, 300);
    };

    newBtn?.addEventListener("click", () => {
      isMenuOpen = !isMenuOpen;
      newBtn.setAttribute("aria-expanded", isMenuOpen.toString());

      if (isMenuOpen) {
        menu.classList.remove("hidden");
        document.body.style.overflow = "hidden";

        requestAnimationFrame(() => {
          menu.classList.remove("opacity-0", "pointer-events-none");
          menu.classList.add("opacity-100", "flex");

          header.classList.remove(
            "bg-linen/95",
            "bg-linen/0",
            "backdrop-blur-md",
            "shadow-[0_1px_0_rgba(20,46,82,0.05)]"
          );
          logo.classList.add("text-linen");
          logo.classList.remove("text-indigo");
          newBtn.classList.add("text-linen");
          newBtn.classList.remove("text-indigo");

          hamburger.classList.add("hidden");
          closeIcon.classList.remove("hidden");
        });
      } else {
        closeMenu();
      }
    });

    // Close the overlay when any mobile nav link is clicked
    menu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", closeMenu);
    });
  }

  // Initialize on full load
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initHeader);
  } else {
    initHeader();
  }
</script>
