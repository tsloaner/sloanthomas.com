---
import ServiceCard from "./ServiceCard.astro";
import ScrollFadeIn from "./ScrollFadeIn.astro";

const services = [
  {
    name: "The Diagnostic",
    description:
      "A focused examination of where your funnel is failing outside of metrics, where friction is killing conversion, and which strategic choices are quietly avoided.",
    href: "/services",
    delay: 0 as const,
  },
  {
    name: "Behavioral Architecture Sprint",
    description:
      "Reimagining and rebuilding your funnel from the first principles of behavioral science within your existing tools. You get a working system with the keys.",
    href: "/services",
    delay: 100 as const,
  },
  {
    name: "Strategic Advisory",
    description:
      "An independent thought partner for leaders who need someone in the room who isn't trying to stay in the room. I'll poke holes in your plan, call out biases, and keep you honest about what your audience responds to.",
    href: "/services",
    delay: 200 as const,
  },
];
---

<section id="services" class="pt-8 pb-24 px-6 relative">
  <div class="max-w-[1200px] w-full mx-auto">
    <ScrollFadeIn delay={0}>
      <h2
        class="font-mono text-[13px] uppercase tracking-[0.05em] text-slate-blue opacity-80 mb-6"
      >
        What I Do
      </h2>
      <p
        class="font-body text-[18px] md:text-[20px] text-slate-blue max-w-[850px] leading-relaxed mb-16"
      >
        Marketing rarely fails from poor execution. It fails because the hardest questions about your brand and strategy never get answered. <strong class="font-semibold text-indigo">I help founders and marketing leaders find the answers and build the systems that follow.</strong>
      </p>
    </ScrollFadeIn>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {services.map((svc) => <ServiceCard {...svc} />)}
    </div>
  </div>
</section>
